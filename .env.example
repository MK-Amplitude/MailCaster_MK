# ------------------------------------------------------------
# MailCaster — 환경변수 예시
# ------------------------------------------------------------
# 로컬 개발용: 이 파일을 `.env.local` 로 복사한 뒤 실제 값 채우기.
#   cp .env.example .env.local
#
# Lovable 배포용: Lovable 프로젝트 설정 → Environment Variables 탭에서
#   아래 두 키를 그대로 추가. (.env.local 은 .gitignore 대상이라 올리지 않음)
#
# 주의:
#   - VITE_ 접두사가 붙은 키만 프론트엔드 번들에 포함됨.
#   - anon key 는 브라우저에 노출되는 것이 정상 — RLS 가 보호함.
#   - service_role key 는 절대 이 파일에 넣지 말 것 (Edge Function 환경변수에서만 사용).
# ------------------------------------------------------------

# Supabase 프로젝트 URL — Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon public key — Dashboard → Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>
